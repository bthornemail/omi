        (path "docs/PHASE-89-RAW-BINARY-DECENTRALIZED-LATTICE-INTEGRATION-AUDIT.md")
        (role raw-binary-lattice-integration-audit))
      (surface
        (sid raw-binary-decentralized-lattice-declaration)
        (path "declarations/raw-binary-decentralized-lattice.omilisp")
        (role raw-binary-lattice-integration-declaration))
      (surface
        (sid phase-90-raw-binary-chunk-receipt-index)
        (path "docs/PHASE-90-RAW-BINARY-CHUNK-RECEIPT-INDEX.md")
        (role raw-binary-chunk-receipt-index-doctrine))
      (surface
        (sid raw-binary-chunk-receipt-index-declaration)
