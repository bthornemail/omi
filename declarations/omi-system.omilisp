        (path "docs/PHASE-93-OMI-OBSERVER-LATTICE-SITTER.md")
        (role observer-lattice-sitter-doctrine))
      (surface
        (sid omi-observer-lattice-sitter-declaration)
        (path "declarations/omi-observer-lattice-sitter.omilisp")
