        (path "docs/PHASE-84-POLYFORM-CONS-RECONSTRUCTION-DOCTRINE.md")
        (role derived-geometry-doctrine))
      (surface
        (sid polyform-cons-reconstruction-declaration)
        (path "declarations/polyform-cons-reconstruction.omilisp")
        (role derived-geometry-declaration))
      (surface
